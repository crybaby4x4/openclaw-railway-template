#!/usr/bin/env bash
set -euo pipefail

HOST="${OPENCLAW_WRAPPER_HOST:-127.0.0.1}"
PORT="${PORT:-8080}"
TOKEN="${INTERNAL_RESTART_TOKEN:-}"
URL="http://${HOST}:${PORT}/internal/api/gateway/restart"

log() {
  echo "[openclaw-gateway-restart] $*"
}

if [[ -z "${TOKEN}" ]]; then
  log "ERROR: INTERNAL_RESTART_TOKEN is not set." >&2
  log "Set INTERNAL_RESTART_TOKEN before running this command." >&2
  exit 1
fi

log "Starting gateway restart request..."
log "Target: ${URL}"
log "Auth: Bearer token from INTERNAL_RESTART_TOKEN"

HTTP_STATUS="$(
  curl -sS -o /tmp/openclaw-gateway-restart-response.$$ -w "%{http_code}" -X POST "${URL}" \
  -H "Authorization: Bearer ${TOKEN}" \
  -H "Content-Type: application/json"
)"

RESPONSE_BODY="$(cat /tmp/openclaw-gateway-restart-response.$$ || true)"
rm -f /tmp/openclaw-gateway-restart-response.$$

if [[ "${HTTP_STATUS}" -ge 200 && "${HTTP_STATUS}" -lt 300 ]]; then
  log "Gateway restart succeeded (HTTP ${HTTP_STATUS})."
  if [[ -n "${RESPONSE_BODY}" ]]; then
    log "Response: ${RESPONSE_BODY}"
  fi
  exit 0
fi

log "Gateway restart failed (HTTP ${HTTP_STATUS})." >&2
if [[ -n "${RESPONSE_BODY}" ]]; then
  log "Response: ${RESPONSE_BODY}" >&2
fi
exit 1

